<Bindings>
    <Binding name="OMNIINVENTORY_TOGGLE" Header="OMNIINVENTORY">
        OmniInventory:Toggle()
    </Binding>
    <Binding name="OMNIINVENTORY_TOGGLE_BANK">
        if OmniInventory.BankFrame then OmniInventory.BankFrame:Toggle() end
    </Binding>
    <Binding name="OMNIINVENTORY_TOGGLE_KEYRING">
        if OmniInventory.Frame then OmniInventory.Frame:ToggleKeyring() end
    </Binding>
    <Binding name="OMNIINVENTORY_OPTIONS">
        if OmniInventory.Settings then OmniInventory.Settings:Toggle() end
    </Binding>
    <Binding name="OMNIINVENTORY_CYCLE_VIEW">
        if OmniInventory.Frame then OmniInventory.Frame:CycleView() end
    </Binding>
    <Binding name="OMNIINVENTORY_CYCLE_SORT">
        if OmniInventory.Frame then OmniInventory.Frame:CycleSort() end
    </Binding>
    <Binding name="OMNIINVENTORY_CLEAR_SEARCH">
        if OmniInventoryFrame and OmniInventoryFrame.searchBox then
            OmniInventoryFrame.searchBox:SetText("")
            OmniInventoryFrame.searchBox:ClearFocus()
        end
    </Binding>
</Bindings>
